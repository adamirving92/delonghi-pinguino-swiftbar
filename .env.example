DELONGHI_EMAIL=you@example.com
DELONGHI_PASSWORD=your-password
DELONGHI_DSN=

# De'Longhi Comfort / Ayla app identifiers.
# This project does not ship vendor app credentials. Provide values from your
# own legitimate client/app configuration.
DELONGHI_API_KEY=
DELONGHI_CLIENT_ID=
DELONGHI_CLIENT_SECRET=
DELONGHI_APP_ID=
DELONGHI_APP_SECRET=

# Optional Tapo/Kasa energy monitor for the SwiftBar widget.
# Use the outlet number for a power strip socket, starting at 1.
AIRCON_TAPO_HOST=
AIRCON_TAPO_OUTLET=1

# Optional electricity pricing for live cost estimates.
# Either set one all-in marginal rate, or set the bill components below.
# Do not include standing charges or late-payment fees here.
AIRCON_ELECTRICITY_RATE_P_PER_KWH=
AIRCON_ELECTRICITY_UNIT_RATE_P_PER_KWH=
AIRCON_ELECTRICITY_CCL_P_PER_KWH=0
AIRCON_ELECTRICITY_VAT_PERCENT=0

# After editing, run:
# ./aircon doctor
